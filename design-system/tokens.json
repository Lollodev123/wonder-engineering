{
  "$comment": "Source of truth for kinetic motion + scene parameters. NOT a website design system. Token names match what the prompt template references.",

  "scene": {
    "environment": "dark-gallery",
    "wall": {
      "color":         "#1A1A1F",
      "ambientLight":  "#2C2C34",
      "groundReflect": 0.18
    },
    "stageLight": {
      "key":  { "color": "#FFFFFF", "intensity": 0.45, "from": [0.0, 1.4, 1.5] },
      "fill": { "color": "#5C68B5", "intensity": 0.20, "from": [-1.5, 0.6, 1.0] },
      "rim":  { "color": "#D86937", "intensity": 0.10, "from": [1.5, 0.4, -1.0] }
    },
    "personScale": {
      "include": true,
      "comment": "A silhouette of a person standing right of the wall sells scale + 'live event' feel. ~1.75 m tall. Dark navy silhouette, slight rim light from the wall."
    }
  },

  "screen": {
    "$comment": "Screens are vibrant gradient surfaces, never white. Tiles can collectively render one image (idle) or fragment to feature callouts (reveal).",
    "gradients": {
      "violet-magenta":  ["#5B2EE8", "#D370E2"],
      "blue-cyan":       ["#1F46E5", "#5DD9F0"],
      "magenta-orange":  ["#E2387A", "#F2A65A"],
      "amber-cream":     ["#F2A65A", "#FFE9C2"],
      "teal-electric":   ["#00C2A8", "#0FE5D2"],
      "navy-violet":     ["#1A1F4E", "#7B3DD9"]
    },
    "callout": {
      "pillBg":          "rgba(0, 0, 0, 0.55)",
      "pillBorder":      "rgba(255, 255, 255, 0.18)",
      "pillTextColor":   "#FFFFFF",
      "highlightAccents": ["#A968FF", "#F2A65A", "#5DD9F0"]
    },
    "connectionLine": {
      "color":  "rgba(255, 255, 255, 0.35)",
      "dash":   [4, 4],
      "width":  1.5
    }
  },

  "monitorWall": {
    "$comment": "Locked geometric template. Coordinates assume canvas 1920×1080 (or scaled).",
    "cols": 5,
    "rows": 3,
    "monitorAspect": 1.778,
    "gap": 24,
    "frameStroke": { "color": "#000000", "width": 0,  "innerGlow": "rgba(255,255,255,0.04)" },
    "anchors": [[1, 1], [2, 1], [3, 1]],
    "wave": {
      "amplitudePx": 18,
      "periodSec": 4.0,
      "phaseStepPerCol": 0.45,
      "phaseStepPerRow": 0.18
    },
    "constraints": {
      "noCollision": true,
      "verticalOrSineOnly": true,
      "phaseShiftedSynchronized": true,
      "$comment": "Three target rules. Checked by generated-artifact defenses, sampled diagnostics, and visual review."
    },
    "stageDurationsSec": {
      "idle":       2.5,
      "transition": 1.5,
      "reveal":     1.6,
      "return":     0.4,
      "totalLoop":  6.0
    }
  },

  "easing": {
    "cinematic":   [0.16, 1.0, 0.30, 1.0],
    "snappy":      [0.40, 0.0, 0.20, 1.0],
    "wave":        "linear",
    "$comment":    "Pass to GSAP as 'cinematic' string keyword (registered) or to CSS as cubic-bezier(...)."
  },

  "tech": {
    "default": "gsap-three",
    "options": ["gsap-three", "gsap-dom", "p5", "gsap-theatre"],
    "cdn": {
      "gsap":     "https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js",
      "three":    "https://cdn.jsdelivr.net/npm/three@0.160.1/build/three.min.js",
      "p5":       "https://cdn.jsdelivr.net/npm/p5@1.9.4/lib/p5.min.js",
      "theatre":  ["https://cdn.jsdelivr.net/npm/@theatre/core@0.7.0/dist/index.min.js"]
    }
  }
}
